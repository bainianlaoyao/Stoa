{
  "name": "stoa",
  "version": "0.3.3",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "out/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && node scripts/build-stoa-ctl.mjs",
    "promo": "tsx --tsconfig tsconfig.node.json tools/promo/index.ts",
    "build:entire-bridge": "node scripts/build-entire-bridge.mjs --build",
    "test:entire-bridge": "node scripts/build-entire-bridge.mjs --test",
    "verify:entire-bridge": "node scripts/build-entire-bridge.mjs",
    "experiment:first-round": "tsc -p tsconfig.experiment-runner.json --outDir .tmp/experiment-runner-build && node scripts/prepare-experiment-runner.mjs && node --experimental-specifier-resolution=node .tmp/experiment-runner-build/scripts/run-real-first-round-experiment-entry.js",
    "preview": "electron-vite preview",
    "package": "node scripts/run-electron-builder.mjs",
    "package:win": "pnpm run build && node scripts/run-electron-builder.mjs --win",
    "package:mac": "pnpm run build && node scripts/run-electron-builder.mjs --mac",
    "package:linux": "pnpm run build && node scripts/run-electron-builder.mjs --linux",
    "package:local": "pnpm run build && pnpm run package",
    "package:release": "pnpm run build && node scripts/run-electron-builder.mjs --publish always",
    "rebuild:native": "node scripts/rebuild-node-pty.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "stoa-ctl": "tsx --tsconfig tsconfig.node.json tools/stoa-ctl/index.ts",
    "verify:icons": "node scripts/validate-ico.mjs build/icons/icon.ico",
    "verify:packaging": "node scripts/verify-packaging-baseline.mjs",
    "verify:release-smoke": "node scripts/smoke-packaged-release.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:generate": "tsx --tsconfig tsconfig.node.json testing/generators/write-generated-playwright.ts",
    "test:e2e": "npm run build && playwright test",
    "test:behavior-coverage": "vitest run testing/generators/behavior-coverage.test.ts",
    "test:all": "npm run test:generate && npm run test && npm run test:e2e && npm run test:behavior-coverage",
    "test:watch": "vitest",
    "ci:local": "pnpm run test:generate && pnpm run typecheck && pnpm vitest run && pnpm run test:e2e && pnpm run test:behavior-coverage && pnpm run build && pnpm run package && pnpm run verify:packaging && pnpm run verify:release-smoke"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "0.12.0-beta.216",
    "@xterm/addon-search": "0.17.0-beta.216",
    "@xterm/addon-serialize": "0.15.0-beta.216",
    "@xterm/addon-unicode11": "0.10.0-beta.216",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "0.20.0-beta.215",
    "@xterm/xterm": "6.1.0-beta.216",
    "better-sqlite3": "^12.9.0",
    "ee-first": "^1.1.1",
    "electron-updater": "^6.8.3",
    "express": "^5.1.0",
    "node-pty": "^1.1.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.22",
    "vue-i18n": "^11.3.2"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "happy-dom": "^18.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "node-pty"
    ]
  }
}
